FROM golang:1.24-alpine AS builder

WORKDIR /app

# Copy go.mod and sum from the root
COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN go build -o /cart-inventory-service ./backend1/main.go

FROM alpine:latest
RUN apk --no-cache add ca-certificates

WORKDIR /

COPY --from=builder /cart-inventory-service /cart-inventory-service
COPY --from=builder /app/config/config.json /config/config.json

ENV CONFIG_PATH=/config/config.json

EXPOSE 8081
CMD ["/cart-inventory-service"]

