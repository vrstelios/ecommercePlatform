FROM golang:1.24-alpine AS builder

RUN apk add --no-cache git

WORKDIR /app

# Copy go.mod and sum from the root
COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /product-service ./backend2/main.go

FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /

COPY --from=builder /product-service /product-service
COPY --from=builder /app/config/config.json /config/config.json

ENV CONFIG_PATH=/config/config.json

EXPOSE 8082 50051
CMD ["/product-service"]
